# ==============================================================================
# RAG2Prod - Environment Configuration Template
# Copy this file to a new file named '.env' and fill in your local variables.
# ==============================================================================

PROJECT_NAME=RAG2Prod
API_V1_STR=/api/v1

# Postgres Configuration (Stage 2)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag2prod

# Vector Database (Stage 2)
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8000

# Graph Database (Stage 18)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j

# LLM Providers & API Keys
# Populate these with your actual provider keys in your local '.env' file.
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
COHERE_API_KEY=your-cohere-api-key-here
